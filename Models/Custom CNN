import torch
import torch.nn as nn
from torchvision.models.detection import FasterRCNN
from torchvision.ops import MultiScaleRoIAlign
from torchvision.models.detection.rpn import AnchorGenerator

# --- Custom Backbone ---
class CustomCNNBackbone(nn.Module):
    def __init__(self):
        super(CustomCNNBackbone, self).__init__()
        self.conv_layers = nn.Sequential(
            nn.Conv2d(3, 32, kernel_size=3, padding=1),
            nn.BatchNorm2d(32), nn.ReLU(), nn.MaxPool2d(2),
            nn.Conv2d(32, 64, kernel_size=3, padding=1),
            nn.BatchNorm2d(64), nn.ReLU(), nn.MaxPool2d(2),
            nn.Conv2d(64, 128, kernel_size=3, padding=1),
            nn.BatchNorm2d(128), nn.ReLU(), nn.MaxPool2d(2),
            nn.Conv2d(128, 256, kernel_size=3, padding=1),
            nn.BatchNorm2d(256), nn.ReLU()
        )
        self.out_channels = 256  # Required for FasterRCNN

    def forward(self, x):
        return self.conv_layers(x)

# --- Model Builder ---
def build_custom_model(num_classes):
    backbone = CustomCNNBackbone()
    
    # Generate anchors for 1 feature map (from the final conv layer)
    anchor_generator = AnchorGenerator(
        sizes=((32, 64, 128, 256, 512),),
        aspect_ratios=((0.5, 1.0, 2.0),)
    )

    # Use MultiScaleRoIAlign instead of nn.Sequential
    roi_pooler = MultiScaleRoIAlign(
        featmap_names=['0'], # '0' is the default name for single-backbone output
        output_size=7,
        sampling_ratio=2
    )

    model = FasterRCNN(
        backbone,
        num_classes=num_classes,
        rpn_anchor_generator=anchor_generator,
        box_roi_pool=roi_pooler
    )
    return model

